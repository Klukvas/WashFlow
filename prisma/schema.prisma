generator client {
  provider = "prisma-client-js"
  output   = "../node_modules/.prisma/client"
}

datasource db {
  provider = "postgresql"
}

// ─── ENUMS ──────────────────────────────────────────────

enum OrderStatus {
  BOOKED
  BOOKED_PENDING_CONFIRMATION
  IN_PROGRESS
  COMPLETED
  CANCELLED
  NO_SHOW
}

enum OrderSource {
  INTERNAL
  WEB
  WIDGET
  API
}

enum PaymentStatus {
  PENDING
  PAID
  PARTIALLY_PAID
  REFUNDED
  FAILED
}

enum PaymentMethod {
  CASH
  CARD
  ONLINE
  OTHER
}

enum AuditAction {
  CREATE
  UPDATE
  DELETE
  STATUS_CHANGE
  MERGE
}

enum PlanTier {
  TRIAL
  STARTER
  BUSINESS
  ENTERPRISE
}

enum BillingInterval {
  MONTHLY
  YEARLY
}

enum SubscriptionStatus {
  TRIALING
  ACTIVE
  PAST_DUE
  PAUSED
  CANCELLED
}

// ─── MODELS ─────────────────────────────────────────────

model Tenant {
  id        String   @id @default(uuid())
  name      String
  slug      String   @unique
  isActive  Boolean  @default(true)
  settings  Json?
  createdAt DateTime @default(now()) @db.Timestamptz
  updatedAt DateTime @updatedAt @db.Timestamptz

  branches         Branch[]
  users            User[]
  roles            Role[]
  clients          Client[]
  vehicles         Vehicle[]
  services         Service[]
  workPosts        WorkPost[]
  orders           Order[]
  payments         Payment[]
  auditLogs        AuditLog[]
  bookingSettings  BookingSettings[]
  employeeProfiles EmployeeProfile[]
  orderServices    OrderService[]
  subscription     Subscription?

  @@map("tenants")
}

model BookingSettings {
  id                    String  @id @default(uuid())
  tenantId              String
  tenant                Tenant  @relation(fields: [tenantId], references: [id])
  branchId              String?
  branch                Branch? @relation(fields: [branchId], references: [id])
  slotDurationMinutes   Int     @default(30)
  bufferTimeMinutes     Int     @default(10)
  maxAdvanceBookingDays Int     @default(30)
  allowOnlineBooking    Boolean @default(true)
  workingHoursStart     String  @default("08:00")
  workingHoursEnd       String  @default("20:00")
  workingDays           Int[]   @default([1, 2, 3, 4, 5, 6])

  @@unique([tenantId, branchId])
  @@map("booking_settings")
}

model Branch {
  id        String    @id @default(uuid())
  tenantId  String
  tenant    Tenant    @relation(fields: [tenantId], references: [id])
  name      String
  address   String?
  phone     String?
  timezone  String    @default("Europe/Kyiv")
  isActive  Boolean   @default(true)
  createdAt DateTime  @default(now()) @db.Timestamptz
  updatedAt DateTime  @updatedAt @db.Timestamptz
  deletedAt DateTime? @db.Timestamptz

  workPosts        WorkPost[]
  orders           Order[]
  users            User[]
  bookingSettings  BookingSettings[]
  employeeProfiles EmployeeProfile[]

  @@index([tenantId])
  @@map("branches")
}

model User {
  id           String    @id @default(uuid())
  tenantId     String
  tenant       Tenant    @relation(fields: [tenantId], references: [id])
  branchId     String?
  branch       Branch?   @relation(fields: [branchId], references: [id])
  email        String
  passwordHash String
  firstName    String
  lastName     String
  phone        String?
  isActive     Boolean   @default(true)
  isSuperAdmin  Boolean   @default(false)
  tokenVersion        Int       @default(0)
  failedLoginAttempts Int       @default(0)
  accountLockedUntil  DateTime? @db.Timestamptz
  roleId              String?
  role          Role?     @relation(fields: [roleId], references: [id])
  createdAt     DateTime  @default(now()) @db.Timestamptz
  updatedAt     DateTime  @updatedAt @db.Timestamptz
  deletedAt     DateTime? @db.Timestamptz

  auditLogs       AuditLog[]
  orders          Order[]    @relation("OrderCreatedBy")
  employeeProfile EmployeeProfile?

  @@unique([email])
  @@index([tenantId])
  @@index([tenantId, branchId])
  @@index([tenantId, roleId])
  @@map("users")
}

model Role {
  id          String    @id @default(uuid())
  tenantId    String
  tenant      Tenant    @relation(fields: [tenantId], references: [id])
  name        String
  description String?
  createdAt   DateTime  @default(now()) @db.Timestamptz
  updatedAt   DateTime  @updatedAt @db.Timestamptz
  deletedAt   DateTime? @db.Timestamptz

  permissions RolePermission[]
  users       User[]

  @@index([tenantId, name])
  @@index([tenantId])
  @@map("roles")
}

model Permission {
  id          String   @id @default(uuid())
  module      String
  action      String
  description String?
  createdAt   DateTime @default(now()) @db.Timestamptz

  roles RolePermission[]

  @@unique([module, action])
  @@map("permissions")
}

model RolePermission {
  id           String     @id @default(uuid())
  roleId       String
  role         Role       @relation(fields: [roleId], references: [id], onDelete: Cascade)
  permissionId String
  permission   Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  @@unique([roleId, permissionId])
  @@index([permissionId])
  @@map("role_permissions")
}

model Client {
  id        String    @id @default(uuid())
  tenantId  String
  tenant    Tenant    @relation(fields: [tenantId], references: [id])
  firstName String
  lastName  String?
  phone     String?
  email     String?
  notes     String?
  createdAt DateTime  @default(now()) @db.Timestamptz
  updatedAt DateTime  @updatedAt @db.Timestamptz
  deletedAt DateTime? @db.Timestamptz

  vehicles Vehicle[]
  orders   Order[]

  @@index([tenantId, phone])
  @@index([tenantId])
  @@map("clients")
}

model Vehicle {
  id           String    @id @default(uuid())
  tenantId     String
  tenant       Tenant    @relation(fields: [tenantId], references: [id])
  clientId     String
  client       Client    @relation(fields: [clientId], references: [id])
  licensePlate String?
  make         String
  model        String?
  color        String?
  year         Int?
  photoUrl     String?
  createdAt    DateTime  @default(now()) @db.Timestamptz
  updatedAt    DateTime  @updatedAt @db.Timestamptz
  deletedAt    DateTime? @db.Timestamptz

  orders Order[]

  @@index([tenantId, licensePlate])
  @@index([tenantId])
  @@index([tenantId, clientId])
  @@map("vehicles")
}

model Service {
  id          String    @id @default(uuid())
  tenantId    String
  tenant      Tenant    @relation(fields: [tenantId], references: [id])
  name        String
  description String?
  durationMin Int
  price       Decimal   @db.Decimal(10, 2)
  isActive    Boolean   @default(true)
  sortOrder   Int       @default(0)
  createdAt   DateTime  @default(now()) @db.Timestamptz
  updatedAt   DateTime  @updatedAt @db.Timestamptz
  deletedAt   DateTime? @db.Timestamptz

  orderServices OrderService[]

  @@index([tenantId])
  @@index([tenantId, isActive])
  @@map("services")
}

model WorkPost {
  id        String    @id @default(uuid())
  tenantId  String
  tenant    Tenant    @relation(fields: [tenantId], references: [id])
  branchId  String
  branch    Branch    @relation(fields: [branchId], references: [id])
  name      String
  isActive  Boolean   @default(true)
  createdAt DateTime  @default(now()) @db.Timestamptz
  updatedAt DateTime  @updatedAt @db.Timestamptz
  deletedAt DateTime? @db.Timestamptz

  orders Order[]

  @@index([tenantId])
  @@index([tenantId, branchId])
  @@map("work_posts")
}

model Order {
  id                 String      @id @default(uuid())
  tenantId           String
  tenant             Tenant      @relation(fields: [tenantId], references: [id])
  branchId           String
  branch             Branch      @relation(fields: [branchId], references: [id])
  clientId           String
  client             Client      @relation(fields: [clientId], references: [id])
  vehicleId          String
  vehicle            Vehicle     @relation(fields: [vehicleId], references: [id])
  workPostId         String?
  workPost           WorkPost?        @relation(fields: [workPostId], references: [id])
  assignedEmployeeId String?
  assignedEmployee   EmployeeProfile? @relation(fields: [assignedEmployeeId], references: [id])
  createdById        String?
  createdBy          User?            @relation("OrderCreatedBy", fields: [createdById], references: [id])
  status             OrderStatus @default(BOOKED)
  source             OrderSource @default(INTERNAL)
  scheduledStart     DateTime    @db.Timestamptz
  scheduledEnd       DateTime    @db.Timestamptz
  totalPrice         Decimal     @default(0) @db.Decimal(10, 2)
  notes              String?
  cancellationReason String?
  createdAt          DateTime    @default(now()) @db.Timestamptz
  updatedAt          DateTime    @updatedAt @db.Timestamptz
  deletedAt          DateTime?   @db.Timestamptz

  services OrderService[]
  payments Payment[]

  @@index([tenantId])
  @@index([tenantId, status])
  @@index([tenantId, branchId, status])
  @@index([tenantId, scheduledStart, scheduledEnd])
  @@index([tenantId, workPostId, scheduledStart, scheduledEnd])
  @@index([tenantId, clientId])
  @@index([tenantId, vehicleId])
  @@index([tenantId, assignedEmployeeId])
  @@map("orders")
}

model OrderService {
  id        String  @id @default(uuid())
  tenantId  String
  tenant    Tenant  @relation(fields: [tenantId], references: [id])
  orderId   String
  order     Order   @relation(fields: [orderId], references: [id], onDelete: Cascade)
  serviceId String
  service   Service @relation(fields: [serviceId], references: [id])
  price     Decimal @db.Decimal(10, 2)
  quantity  Int     @default(1)

  @@index([orderId])
  @@index([serviceId])
  @@map("order_services")
}

model Payment {
  id        String        @id @default(uuid())
  tenantId  String
  tenant    Tenant        @relation(fields: [tenantId], references: [id])
  orderId   String
  order     Order         @relation(fields: [orderId], references: [id])
  amount    Decimal       @db.Decimal(10, 2)
  method    PaymentMethod
  status    PaymentStatus @default(PENDING)
  reference String?
  createdAt DateTime      @default(now()) @db.Timestamptz
  updatedAt DateTime      @updatedAt @db.Timestamptz

  @@index([tenantId])
  @@index([tenantId, orderId])
  @@map("payments")
}

model AuditLog {
  id            String      @id @default(uuid())
  tenantId      String
  tenant        Tenant      @relation(fields: [tenantId], references: [id])
  entityType    String
  entityId      String
  action        AuditAction
  oldValue      Json?
  newValue      Json?
  performedById String?
  performedBy   User?       @relation(fields: [performedById], references: [id])
  metadata      Json?
  createdAt     DateTime    @default(now()) @db.Timestamptz

  @@index([tenantId])
  @@index([tenantId, entityType, entityId])
  @@index([tenantId, createdAt])
  @@map("audit_logs")
}

model IdempotencyKey {
  id           String   @id @default(uuid())
  key          String
  tenantId     String
  method       String
  path         String
  statusCode   Int      @default(0)
  responseBody Json     @default("{}")
  createdAt    DateTime @default(now()) @db.Timestamptz
  expiresAt    DateTime @db.Timestamptz

  @@unique([tenantId, key])
  @@index([expiresAt])
  @@map("idempotency_keys")
}

model EmployeeProfile {
  id                    String    @id @default(uuid())
  tenantId              String
  userId                String    @unique
  branchId              String
  isWorker              Boolean   @default(true)
  efficiencyCoefficient Float     @default(1)
  active                Boolean   @default(true)
  workStartTime         String?
  workEndTime           String?
  createdAt             DateTime  @default(now()) @db.Timestamptz
  updatedAt             DateTime  @updatedAt @db.Timestamptz
  deletedAt             DateTime? @db.Timestamptz

  tenant  Tenant  @relation(fields: [tenantId], references: [id])
  user    User    @relation(fields: [userId], references: [id])
  branch  Branch  @relation(fields: [branchId], references: [id])
  orders  Order[]

  @@index([tenantId])
  @@index([tenantId, branchId])
  @@map("employee_profiles")
}

model Subscription {
  id                   String             @id @default(uuid())
  tenantId             String             @unique
  tenant               Tenant             @relation(fields: [tenantId], references: [id])
  planTier             PlanTier           @default(TRIAL)
  billingInterval      BillingInterval?
  status               SubscriptionStatus @default(TRIALING)
  maxUsers             Int?
  maxBranches          Int?
  maxWorkPosts         Int?
  maxServices          Int?
  isTrial              Boolean            @default(false)
  trialEndsAt          DateTime?          @db.Timestamptz
  paddleSubscriptionId String?
  paddleCustomerId     String?
  paddleStatus         String?
  paddlePriceId        String?
  currentPeriodStart   DateTime?          @db.Timestamptz
  currentPeriodEnd     DateTime?          @db.Timestamptz
  cancelledAt          DateTime?          @db.Timestamptz
  cancelEffectiveAt    DateTime?          @db.Timestamptz
  createdAt            DateTime           @default(now()) @db.Timestamptz
  updatedAt            DateTime           @updatedAt @db.Timestamptz

  addons SubscriptionAddon[]

  @@map("subscriptions")
}

model SubscriptionAddon {
  id             String       @id @default(uuid())
  subscriptionId String
  subscription   Subscription @relation(fields: [subscriptionId], references: [id], onDelete: Cascade)
  resource       String       // 'branches' | 'workPosts' | 'users' | 'services'
  quantity       Int          @default(1)
  paddlePriceId  String?
  createdAt      DateTime     @default(now()) @db.Timestamptz
  updatedAt      DateTime     @updatedAt @db.Timestamptz

  @@unique([subscriptionId, resource])
  @@map("subscription_addons")
}

model PasswordResetToken {
  id        String    @id @default(uuid())
  userId    String
  token     String    @unique
  expiresAt DateTime  @db.Timestamptz
  usedAt    DateTime? @db.Timestamptz
  createdAt DateTime  @default(now()) @db.Timestamptz

  @@index([token])
  @@index([userId])
  @@map("password_reset_tokens")
}
