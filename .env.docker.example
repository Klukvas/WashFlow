# Docker Compose environment variables
POSTGRES_DB=washflow
POSTGRES_USER=washflow
POSTGRES_PASSWORD=CHANGE_ME_TO_A_STRONG_PASSWORD

JWT_ACCESS_SECRET=CHANGE_ME_GENERATE_WITH_openssl_rand_base64_64
JWT_REFRESH_SECRET=CHANGE_ME_GENERATE_WITH_openssl_rand_base64_64

CORS_ORIGINS=http://localhost:5173

REDIS_PASSWORD=CHANGE_ME_TO_A_STRONG_PASSWORD

# Frontend URL (for password reset links)
FRONTEND_URL=https://washflow.app

# Resend Email (optional — leave empty to disable)
RESEND_API_KEY=

# Paddle Billing (optional — leave empty to disable)
PADDLE_API_KEY=
PADDLE_CLIENT_TOKEN=
PADDLE_WEBHOOK_SECRET=
# PADDLE_ADDON_PRICE_IDS='{"branches":"pri_xxx","workPosts":"pri_xxx","users":"pri_xxx","services":"pri_xxx"}'

# Grafana Cloud Loki (optional — leave empty to disable)
GRAFANA_LOKI_HOST=
GRAFANA_LOKI_USERNAME=
GRAFANA_LOKI_PASSWORD=

# Sentry (optional — leave empty to disable)
SENTRY_DSN=
VITE_SENTRY_DSN=
