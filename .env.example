# Database
DATABASE_URL="postgresql://USER:PASSWORD@HOST:PORT/DATABASE"

# Redis
REDIS_URL="redis://HOST:PORT"

# JWT
JWT_ACCESS_SECRET="your-access-secret-min-32-characters-long"
JWT_REFRESH_SECRET="your-refresh-secret-min-32-characters-long"

# JWT Expiration
JWT_ACCESS_EXPIRATION="15m"
JWT_REFRESH_EXPIRATION="7d"

# Server
PORT=3000
NODE_ENV="development"

# CORS
CORS_ORIGINS="http://localhost:5173"

# Sentry (optional — leave empty to disable)
SENTRY_DSN=""
VITE_SENTRY_DSN=""
# SENTRY_TRACES_SAMPLE_RATE=0.05

# Resend Email (optional — leave empty to disable)
# RESEND_API_KEY=""
# EMAIL_FROM="WashFlow <noreply@washflow.app>"

# Frontend URL (for password reset links)
FRONTEND_URL="http://localhost:5173"

# Metrics (optional — set to protect /metrics endpoint with Bearer token)
# METRICS_TOKEN=""

# Grafana Cloud Loki (optional — leave empty to disable)
# GRAFANA_LOKI_HOST="https://logs-prod-xxx.grafana.net"
# GRAFANA_LOKI_USERNAME="123456"
# GRAFANA_LOKI_PASSWORD="glc_xxxxx"

# Paddle Billing (optional — leave empty to disable)
# PADDLE_API_KEY=""
# PADDLE_CLIENT_TOKEN=""
# PADDLE_WEBHOOK_SECRET=""
# PADDLE_SANDBOX="true"
# PADDLE_PRICE_IDS='{"starter_monthly":"pri_xxx","starter_yearly":"pri_xxx"}'
# PADDLE_ADDON_PRICE_IDS='{"branches":"pri_xxx","workPosts":"pri_xxx","users":"pri_xxx","services":"pri_xxx"}'
